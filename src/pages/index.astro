---
export const prerender = false;
import Base from '../layouts/Base.astro';
import GlassCard from '../components/glass/GlassCard.astro';
import { getCollection } from 'astro:content';
import { getSettings } from '../lib/kv';

// env is now imported via cloudflare:workers inside getSettings
const settings = await getSettings();

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const avatarUrl = settings.avatarUrl || `https://q.qlogo.cn/g?b=qq&nk=${settings.qqNumber}&s=100`;
const hasBackground = settings.backgroundUrl && settings.backgroundUrl.trim() !== '';
---

<Base title={`${settings.nickname || 'TIins'} - ${settings.heroTitle || '液态玻璃'} ${settings.heroSubtitle || 'Blog'}`}>

  {/* Background: image or gradient orbs */}
  {hasBackground ? (
    <div class="fixed inset-0 z-0">
      <img
        src={settings.backgroundUrl}
        alt=""
        class="w-full h-full object-cover opacity-20"
        style="filter: blur(16px) brightness(0.4);"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-[var(--gradient-start)]/60 via-transparent to-[var(--gradient-end)]/80"></div>
    </div>
  ) : (
    <div class="absolute inset-0 overflow-hidden pointer-events-none" style="z-index: 0;">
      <div class="absolute w-[500px] h-[500px] rounded-full bg-purple-600/20 blur-[120px] animate-float" style="top: -10%; left: -5%;"></div>
      <div class="absolute w-[400px] h-[400px] rounded-full bg-cyan-500/15 blur-[100px] animate-float" style="bottom: -5%; right: -5%; animation-delay: -3s;"></div>
      <div class="absolute w-[300px] h-[300px] rounded-full bg-violet-500/10 blur-[80px] animate-float" style="top: 40%; left: 50%; animation-delay: -1.5s;"></div>
    </div>
  )}

  {/* Profile + Hero Section */}
  <section class="relative min-h-[80vh] flex items-center justify-center overflow-hidden">
    <div class="relative z-10 w-full max-w-3xl mx-auto px-6 py-12">
      <GlassCard class="text-center p-10 md:p-14" hover={false}>
        {/* Avatar with gradient ring */}
        <div class="flex justify-center mb-8 animate-fade-in">
          <div class="relative">
            {/* Outer glow ring */}
            <div
              class="absolute -inset-1.5 rounded-full opacity-70 animate-pulse-glow"
              style="background: linear-gradient(135deg, var(--color-primary-light), var(--color-accent-light));"
            ></div>
            {/* Avatar image */}
            <img
              src={avatarUrl}
              alt={settings.nickname || 'TIins'}
              class="relative w-28 h-28 md:w-32 md:h-32 rounded-full object-cover border-4 border-white/10"
              style="background: var(--bg-secondary);"
            />
            {/* Online dot */}
            <div class="absolute bottom-1 right-1 w-4 h-4 rounded-full bg-green-400 border-2 border-[var(--bg-secondary)] shadow-lg shadow-green-400/50"></div>
          </div>
        </div>

        {/* Nickname */}
        <h1 class="text-4xl md:text-5xl font-extrabold mb-3 animate-slide-up">
          <span class="text-gradient">{settings.nickname || 'TIins'}</span>
        </h1>

        {/* Signature / Bio */}
        <p class="text-base md:text-lg max-w-md mx-auto mb-2 animate-slide-up" style="color: var(--text-secondary); animation-delay: 0.15s;">
          {settings.signature || '保持热爱，奔赴山海 ✨'}
        </p>

        {/* Tagline */}
        <p class="text-sm mb-8 animate-slide-up" style="color: var(--text-muted); animation-delay: 0.2s;">
          {settings.heroDescription || '一个融合了现代设计美学与前沿前端技术的个人博客'}
        </p>

        {/* CTA buttons */}
        <div class="flex items-center justify-center gap-4 animate-slide-up" style="animation-delay: 0.3s;">
          <a
            href="/blog"
            class="ripple glass-strong px-8 py-3 rounded-xl text-sm font-semibold text-white hover:opacity-90 transition-opacity"
          >
            浏览文章 →
          </a>
          <a
            href="/tags"
            class="ripple glass px-8 py-3 rounded-xl text-sm font-semibold transition-all hover:bg-white/10"
            style="color: var(--text-primary);"
          >
            按标签探索
          </a>
        </div>

        {/* Stats / badges */}
        <div class="flex items-center justify-center gap-6 mt-8 text-xs" style="color: var(--text-muted);">
          <span class="flex items-center gap-1.5">
            <span class="w-2 h-2 rounded-full bg-green-400 inline-block"></span>
            Active
          </span>
          <span>QQ {settings.qqNumber}</span>
          <span>🌙 {settings.theme === 'light' ? 'Light' : 'Dark'}</span>
        </div>
      </GlassCard>
    </div>

    {/* Scroll Indicator */}
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 animate-float z-10">
      <div class="w-5 h-8 rounded-full border-2 border-white/20 flex justify-center pt-1.5">
        <div class="w-1 h-2 rounded-full bg-white/40 animate-bounce"></div>
      </div>
    </div>
  </section>

  {/* Latest Posts */}
  {posts.length > 0 && (
    <section class="max-w-6xl mx-auto px-6 py-16 relative z-10">
      <div class="flex items-center justify-between mb-10">
        <h2 class="text-2xl font-bold" style="color: var(--text-primary);">最新文章</h2>
        <a href="/blog" class="text-sm font-medium text-purple-400 hover:text-purple-300 transition-colors">
          查看全部 →
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post, i) => (
          <a href={`/blog/${post.id}`} class="block group">
            <GlassCard class="h-full animate-slide-up" style={{ animationDelay: `${i * 0.1}s` }}>
              <div class="flex items-center gap-2 mb-3">
                {post.data.tags?.slice(0, 2).map((tag) => (
                  <span class="text-xs px-2 py-0.5 rounded-full bg-purple-500/20 text-purple-300">
                    {tag}
                  </span>
                ))}
              </div>
              <h3 class="text-lg font-bold mb-2 group-hover:text-purple-400 transition-colors" style="color: var(--text-primary);">
                {post.data.title}
              </h3>
              <p class="text-sm mb-4 line-clamp-2" style="color: var(--text-secondary);">
                {post.data.description}
              </p>
              <div class="text-xs" style="color: var(--text-muted);">
                {post.data.date.toLocaleDateString('zh-CN')}
              </div>
            </GlassCard>
          </a>
        ))}
      </div>
    </section>
  )}

  {/* Footer is inside Base.astro — rendered automatically */}
</Base>

