---
import Base from '../../layouts/Base.astro';
import GlassCard from '../../components/glass/GlassCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).filter((p) => !p.data.draft);
const tagCount: Record<string, number> = {};
posts.forEach((post) => {
  post.data.tags.forEach((tag) => {
    tagCount[tag] = (tagCount[tag] || 0) + 1;
  });
});

const sortedTags = Object.entries(tagCount).sort((a, b) => b[1] - a[1]);
---

<Base title="标签 | 液态玻璃 Blog" description="按标签浏览文章">
  <section class="max-w-6xl mx-auto px-6 py-12">
    <h1 class="text-3xl md:text-4xl font-extrabold mb-4 animate-slide-up">
      <span class="text-gradient">标签</span>
    </h1>
    <p class="mb-10 animate-slide-up" style="color: var(--text-secondary); animation-delay: 0.1s;">
      共 {sortedTags.length} 个标签
    </p>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      {sortedTags.map(([tag, count], i) => (
        <a href={`/tags/${tag}`} class="block group animate-slide-up" style={`animation-delay: ${0.05 * i}s`}>
          <GlassCard class="text-center">
            <div class="text-xl font-bold mb-1 group-hover:text-purple-400 transition-colors" style="color: var(--text-primary);">
              {tag}
            </div>
            <div class="text-sm" style="color: var(--text-muted);">
              {count} 篇文章
            </div>
          </GlassCard>
        </a>
      ))}
    </div>

    {sortedTags.length === 0 && (
      <div class="text-center py-20">
        <p class="text-lg" style="color: var(--text-muted);">暂无标签</p>
      </div>
    )}
  </section>
</Base>
