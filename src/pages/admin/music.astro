---
export const prerender = false;
import Admin from '../../layouts/Admin.astro';
---

<Admin title="音乐管理 | 管理后台">
  <div class="max-w-5xl mx-auto px-6">
    <div class="mb-8 animate-slide-up">
      <a href="/admin" class="text-sm mb-4 inline-block transition-colors hover:text-purple-400" style="color: var(--text-muted);">← 返回仪表盘</a>
      <h1 class="text-3xl font-bold" style="color: var(--text-primary);">🎵 音乐管理</h1>
      <p class="mt-2" style="color: var(--text-secondary);">搜索在线音乐、管理曲目和播放列表</p>
    </div>

    {/* Tabs */}
    <div class="flex gap-1 p-1 rounded-xl mb-6" style="background: var(--glass-bg); border: 1px solid var(--glass-border);">
      <button onclick="switchTab('search')" id="tab-search" class="flex-1 py-2 rounded-lg text-sm font-medium transition-all tab-active">🔍 搜索</button>
      <button onclick="switchTab('playlist')" id="tab-playlist" class="flex-1 py-2 rounded-lg text-sm font-medium transition-all tab-inactive">📋 播放列表</button>
      <button onclick="switchTab('favorites')" id="tab-favorites" class="flex-1 py-2 rounded-lg text-sm font-medium transition-all tab-inactive">❤️ 收藏</button>
    </div>

    {/* Search Tab */}
    <div id="panel-search" class="tab-panel">
      <div class="flex gap-3 mb-6">
        <input id="search-input" type="text" placeholder="搜索歌曲、歌手..." class="flex-1 px-4 py-2.5 rounded-xl text-sm" style="background: var(--glass-bg); border: 1px solid var(--glass-border); color: var(--text-primary);" onkeydown="if(event.key==='Enter')doSearch()" />
        <button onclick="doSearch()" class="px-5 py-2.5 rounded-xl text-sm font-semibold text-white bg-gradient-to-r from-purple-500 to-cyan-400 hover:opacity-90 transition-opacity">搜索</button>
      </div>
      <div id="search-results" class="space-y-2"></div>
      <div id="search-status" class="text-center text-sm py-4 hidden" style="color: var(--text-muted);"></div>
    </div>

    {/* Playlist Tab */}
    <div id="panel-playlist" class="tab-panel hidden">
      <div id="playlist-tracks" class="space-y-2"></div>
      <div class="mt-4 flex gap-3">
        <button onclick="savePlaylist()" class="px-5 py-2.5 rounded-xl text-sm font-semibold text-white bg-gradient-to-r from-purple-500 to-cyan-400 hover:opacity-90 transition-opacity">💾 保存播放列表</button>
        <button onclick="clearPlaylist()" class="px-4 py-2 rounded-xl text-sm font-medium glass" style="color: var(--text-muted); border: 1px solid var(--glass-border);">🗑️ 清空</button>
      </div>
      <div id="playlist-status" class="text-center text-sm mt-3 hidden"></div>
    </div>

    {/* Favorites Tab */}
    <div id="panel-favorites" class="tab-panel hidden">
      <div id="favorites-list" class="space-y-2"></div>
      <div class="mt-4 flex gap-3">
        <button onclick="importFavorites()" class="px-4 py-2 rounded-xl text-sm font-medium glass" style="color: var(--text-primary); border: 1px solid var(--glass-border);">📥 导入到播放列表</button>
        <button onclick="saveFavorites()" class="px-5 py-2.5 rounded-xl text-sm font-semibold text-white bg-gradient-to-r from-purple-500 to-cyan-400 hover:opacity-90 transition-opacity">💾 保存收藏</button>
      </div>
      <div id="favorites-status" class="text-center text-sm mt-3 hidden"></div>
    </div>
  </div>
</Admin>

<style>
  .tab-active { background: linear-gradient(135deg, var(--accent-1), var(--accent-2)); color: white; }
  .tab-inactive { color: var(--text-muted); }
  .tab-inactive:hover { color: var(--text-primary); }
  .search-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; border-radius: 0.75rem; background: var(--glass-bg); border: 1px solid var(--glass-border); transition: all 0.2s; }
  .search-item:hover { border-color: var(--accent-1); background: rgba(255,255,255,0.08); }
  .search-item .si-art { width: 3rem; height: 3rem; border-radius: 0.5rem; object-fit: cover; background: linear-gradient(135deg, var(--accent-1), var(--accent-2)); flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; }
  .si-info { flex: 1; min-width: 0; }
  .si-title { font-size: 0.8rem; font-weight: 600; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .si-artist { font-size: 0.7rem; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .si-album { font-size: 0.6rem; color: var(--text-muted); }
  .si-actions { display: flex; gap: 0.375rem; flex-shrink: 0; }
  .si-btn { padding: 0.375rem 0.625rem; border-radius: 0.5rem; border: 1px solid var(--glass-border); background: var(--glass-bg); color: var(--text-primary); font-size: 0.7rem; cursor: pointer; transition: all 0.2s; white-space: nowrap; }
  .si-btn:hover { border-color: var(--accent-1); }
  .si-btn-play { background: linear-gradient(135deg, var(--accent-1), var(--accent-2)); color: white; border-color: transparent; }
  .si-btn-fav { color: #ef4444; }
  .si-btn-fav.active { background: rgba(239,68,68,0.15); border-color: #ef4444; }
  .si-duration { font-size: 0.6rem; color: var(--text-muted); font-family: monospace; flex-shrink: 0; }
  .audio-preview { width: 100%; height: 36px; margin-top: 0.25rem; border-radius: 0.5rem; }
</style>

<script is:inline>
  (function() {
    if (!localStorage.getItem('admin_token')) {
      window.location.href = '/admin/login';
      return;
    }
    loadPlaylist();
    loadFavorites();
  })();

  var playlist = [];
  var favorites = [];
  var currentAudio = null;

  // Tab switching
  function switchTab(tab) {
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.add('hidden'));
    document.getElementById('panel-' + tab).classList.remove('hidden');
    document.querySelectorAll('[id^="tab-"]').forEach(b => { b.className = 'flex-1 py-2 rounded-lg text-sm font-medium transition-all tab-inactive'; });
    document.getElementById('tab-' + tab).className = 'flex-1 py-2 rounded-lg text-sm font-medium transition-all tab-active';
  }

  // Search
  function doSearch() {
    var q = document.getElementById('search-input').value.trim();
    if (!q) return;
    var status = document.getElementById('search-status');
    var results = document.getElementById('search-results');
    status.className = 'text-center text-sm py-4';
    status.style.color = 'var(--text-muted)';
    status.textContent = '搜索中...';
    status.classList.remove('hidden');
    results.innerHTML = '';

    fetch('/api/music/search?q=' + encodeURIComponent(q))
      .then(function(r) { return r.json(); })
      .then(function(data) {
        status.classList.add('hidden');
        var songs = data.songs || [];
        if (songs.length === 0) {
          results.innerHTML = '<div class="text-center py-8 text-sm" style="color:var(--text-muted);">未找到结果</div>';
          return;
        }
        results.innerHTML = songs.map(function(s, i) {
          var isFav = favorites.some(function(f) { return f.id === s.id; });
          var dur = Math.floor(s.duration / 60) + ':' + String(s.duration % 60).padStart(2, '0');
          return '<div class="search-item">' +
            '<div class="si-art">' + (s.cover ? '<img src="' + s.cover + '" class="w-full h-full rounded-lg object-cover" onerror="this.parentElement.textContent=\'🎵\'" />' : '🎵') + '</div>' +
            '<div class="si-info"><div class="si-title">' + escHtml(s.title) + '</div><div class="si-artist">' + escHtml(s.artist) + '</div><div class="si-album">' + escHtml(s.album) + '</div>' +
            '<audio class="audio-preview" controls preload="none" src="' + s.src + '"></audio></div>' +
            '<span class="si-duration">' + dur + '</span>' +
            '<div class="si-actions">' +
              '<button class="si-btn" onclick="playSong(\'' + escAttr(s.src) + '\',\'' + escAttr(s.title) + '\',\'' + escAttr(s.artist) + '\')" title="播放">▶</button>' +
              '<button class="si-btn" onclick="addToPlaylist(' + i + ')" title="加入播放列表">📋</button>' +
              '<button class="si-btn si-btn-fav ' + (isFav ? 'active' : '') + '" onclick="toggleFavorite(' + i + ')" title="收藏">' + (isFav ? '❤️' : '🤍') + '</button>' +
            '</div>' +
          '</div>';
        }).join('');
        window._searchResults = songs;
      })
      .catch(function(e) {
        status.textContent = '❌ 搜索失败: ' + e.message;
        status.style.color = '#ef4444';
      });
  }

  // Play
  function playSong(src, title, artist) {
    if (currentAudio) { currentAudio.pause(); currentAudio = null; }
    currentAudio = new Audio(src);
    currentAudio.play().catch(function() {});
    window.dispatchEvent(new CustomEvent('play-music', { detail: { src: src } }));
  }

  // Playlist
  function addToPlaylist(idx) {
    var s = window._searchResults && window._searchResults[idx];
    if (!s) return;
    playlist.push({ title: s.title, artist: s.artist, src: s.src, cover: s.cover, id: s.id, album: s.album, duration: s.duration });
    renderPlaylist();
  }

  function removeFromPlaylist(i) { playlist.splice(i, 1); renderPlaylist(); }

  function movePlaylistItem(i, dir) {
    var j = i + dir;
    if (j < 0 || j >= playlist.length) return;
    var tmp = playlist[i]; playlist[i] = playlist[j]; playlist[j] = tmp;
    renderPlaylist();
  }

  function renderPlaylist() {
    var c = document.getElementById('playlist-tracks');
    if (playlist.length === 0) {
      c.innerHTML = '<div class="text-center py-8 text-sm" style="color:var(--text-muted);">播放列表为空，去搜索页添加歌曲吧</div>';
      return;
    }
    c.innerHTML = playlist.map(function(t, i) {
      var dur = t.duration ? Math.floor(t.duration / 60) + ':' + String(t.duration % 60).padStart(2, '0') : '--:--';
      return '<div class="search-item">' +
        '<div class="si-art" style="width:2.5rem;height:2.5rem;font-size:0.9rem;">' + (t.cover ? '<img src="' + t.cover + '" class="w-full h-full rounded-lg object-cover" onerror="this.parentElement.textContent=\'🎵\'" />' : '🎵') + '</div>' +
        '<div class="si-info"><div class="si-title">' + escHtml(t.title) + '</div><div class="si-artist">' + escHtml(t.artist) + '</div></div>' +
        '<span class="si-duration">' + dur + '</span>' +
        '<div class="si-actions">' +
          '<button class="si-btn" onclick="movePlaylistItem(' + i + ',-1)" title="上移">⬆</button>' +
          '<button class="si-btn" onclick="movePlaylistItem(' + i + ',1)" title="下移">⬇</button>' +
          '<button class="si-btn si-btn-play" onclick="playSong(\'' + escAttr(t.src) + '\',\'' + escAttr(t.title) + '\',\'' + escAttr(t.artist) + '\')" title="播放">▶</button>' +
          '<button class="si-btn" onclick="removeFromPlaylist(' + i + ')" title="移除" style="color:#ef4444;">✕</button>' +
        '</div>' +
      '</div>';
    }).join('');
  }

  function savePlaylist() {
    var st = document.getElementById('playlist-status');
    st.className = 'text-center text-sm mt-3';
    st.style.color = 'var(--text-muted)';
    st.textContent = '保存中...';
    fetch('/api/music', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ tracks: playlist }) })
      .then(function(r) { return r.json(); })
      .then(function(d) { st.textContent = d.ok ? '✅ 播放列表已保存' : '❌ 保存失败'; st.style.color = d.ok ? '#22c55e' : '#ef4444'; })
      .catch(function() { st.textContent = '❌ 网络错误'; st.style.color = '#ef4444'; });
    setTimeout(function() { st.classList.add('hidden'); }, 3000);
  }

  function clearPlaylist() { if (confirm('确定清空播放列表？')) { playlist = []; renderPlaylist(); } }

  function loadPlaylist() {
    fetch('/api/music').then(function(r) { return r.json(); }).then(function(d) {
      playlist = Array.isArray(d) ? d : [];
      renderPlaylist();
    }).catch(function() {});
  }

  // Favorites
  function toggleFavorite(idx) {
    var s = window._searchResults && window._searchResults[idx];
    if (!s) return;
    var existIdx = favorites.findIndex(function(f) { return f.id === s.id; });
    if (existIdx >= 0) { favorites.splice(existIdx, 1); } else { favorites.push({ title: s.title, artist: s.artist, src: s.src, cover: s.cover, id: s.id, album: s.album, duration: s.duration }); }
    doSearch(); // re-render search results
    renderFavorites();
  }

  function removeFavorite(i) { favorites.splice(i, 1); renderFavorites(); }

  function renderFavorites() {
    var c = document.getElementById('favorites-list');
    if (favorites.length === 0) {
      c.innerHTML = '<div class="text-center py-8 text-sm" style="color:var(--text-muted);">暂无收藏</div>';
      return;
    }
    c.innerHTML = favorites.map(function(t, i) {
      var dur = t.duration ? Math.floor(t.duration / 60) + ':' + String(t.duration % 60).padStart(2, '0') : '--:--';
      return '<div class="search-item">' +
        '<div class="si-art" style="width:2.5rem;height:2.5rem;font-size:0.9rem;">' + (t.cover ? '<img src="' + t.cover + '" class="w-full h-full rounded-lg object-cover" onerror="this.parentElement.textContent=\'🎵\'" />' : '🎵') + '</div>' +
        '<div class="si-info"><div class="si-title">' + escHtml(t.title) + '</div><div class="si-artist">' + escHtml(t.artist) + '</div></div>' +
        '<span class="si-duration">' + dur + '</span>' +
        '<div class="si-actions">' +
          '<button class="si-btn si-btn-play" onclick="playSong(\'' + escAttr(t.src) + '\',\'' + escAttr(t.title) + '\',\'' + escAttr(t.artist) + '\')" title="播放">▶</button>' +
          '<button class="si-btn" onclick="removeFavorite(' + i + ')" title="取消收藏" style="color:#ef4444;">✕</button>' +
        '</div>' +
      '</div>';
    }).join('');
  }

  function saveFavorites() {
    var st = document.getElementById('favorites-status');
    st.className = 'text-center text-sm mt-3';
    st.style.color = 'var(--text-muted)';
    st.textContent = '保存中...';
    fetch('/api/music/favorites', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ favorites: favorites }) })
      .then(function(r) { return r.json(); })
      .then(function(d) { st.textContent = d.ok ? '✅ 收藏已保存' : '❌ 保存失败'; st.style.color = d.ok ? '#22c55e' : '#ef4444'; })
      .catch(function() { st.textContent = '❌ 网络错误'; st.style.color = '#ef4444'; });
    setTimeout(function() { st.classList.add('hidden'); }, 3000);
  }

  function importFavorites() {
    favorites.forEach(function(s) {
      if (!playlist.some(function(p) { return p.id === s.id; })) {
        playlist.push(Object.assign({}, s));
      }
    });
    renderPlaylist();
    alert('已导入 ' + favorites.length + ' 首收藏到播放列表');
  }

  function loadFavorites() {
    fetch('/api/music/favorites').then(function(r) { return r.json(); }).then(function(d) {
      favorites = Array.isArray(d) ? d : [];
      renderFavorites();
    }).catch(function() {});
  }

  // Helpers
  function escHtml(s) { return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
  function escAttr(s) { return String(s || '').replace(/\\/g,'\\\\').replace(/'/g,"\\'"); }
</script>