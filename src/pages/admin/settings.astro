---
export const prerender = false;
import Admin from '../../layouts/Admin.astro';
---

<Admin title="站点设置 | 管理后台">
  <div class="max-w-4xl mx-auto px-6">
    <div class="mb-8 animate-slide-up">
      <a href="/admin" class="text-sm mb-4 inline-block transition-colors hover:opacity-80" style="color: var(--text-muted);">← 返回仪表盘</a>
      <h1 class="text-3xl font-bold" style="color: var(--text-primary);">⚙️ 站点设置</h1>
      <p class="mt-2" style="color: var(--text-secondary);">管理你的博客个性化配置，所有设置跨设备同步保存到 Cloudflare KV</p>
    </div>

    <div id="settings-form" class="space-y-6">
      {/* ===== 个人信息 ===== */}
      <div class="glass-card rounded-2xl p-6 animate-slide-up" style="animation-delay: 0.05s;">
        <h2 class="text-lg font-bold mb-4" style="color: var(--text-primary);">👤 个人信息</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div><label class="block text-sm mb-1" style="color: var(--text-secondary);">昵称</label><input id="nickname" type="text" class="service-input" /></div>
          <div><label class="block text-sm mb-1" style="color: var(--text-secondary);">QQ号</label><input id="qqNumber" type="text" class="service-input" /></div>
          <div class="md:col-span-2"><label class="block text-sm mb-1" style="color: var(--text-secondary);">个性签名</label><input id="signature" type="text" class="service-input" /></div>
          <div class="md:col-span-2"><label class="block text-sm mb-1" style="color: var(--text-secondary);">头像URL（留空则使用QQ头像）</label><input id="avatarUrl" type="text" class="service-input" placeholder="https://..." /></div>
        </div>
        <div class="mt-4 flex items-center gap-4">
          <div class="w-16 h-16 rounded-full p-0.5 bg-gradient-to-br from-purple-500 to-cyan-400"><img id="avatar-preview" src="" class="w-full h-full rounded-full object-cover" alt="avatar" /></div>
          <span class="text-sm" style="color: var(--text-muted);">头像预览</span>
        </div>
      </div>

      {/* ===== 首页 Hero 区域 ===== */}
      <div class="glass-card rounded-2xl p-6 animate-slide-up" style="animation-delay: 0.1s;">
        <h2 class="text-lg font-bold mb-4" style="color: var(--text-primary);">🏠 首页 Hero 区域</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div><label class="block text-sm mb-1" style="color: var(--text-secondary);">欢迎 Emoji</label><input id="heroEmoji" type="text" class="service-input" placeholder="👋" /></div>
          <div><label class="block text-sm mb-1" style="color: var(--text-secondary);">欢迎标语（用 %s 代替昵称）</label><input id="heroTagline" type="text" class="service-input" placeholder="Hi, Welcome! I'm %s!" /></div>
          <div><label class="block text-sm mb-1" style="color: var(--text-secondary);">首页标题</label><input id="heroTitle" type="text" class="service-input" /></div>
          <div><label class="block text-sm mb-1" style="color: var(--text-secondary);">首页副标题</label><input id="heroSubtitle" type="text" class="service-input" /></div>
          <div class="md:col-span-2"><label class="block text-sm mb-1" style="color: var(--text-secondary);">首页描述</label><input id="heroDescription" type="text" class="service-input" /></div>
        </div>
      </div>

      {/* ===== 外观设置 ===== */}
      <div class="glass-card rounded-2xl p-6 animate-slide-up" style="animation-delay: 0.15s;">
        <h2 class="text-lg font-bold mb-4" style="color: var(--text-primary);">🎨 外观设置</h2>
        <div class="space-y-4">
          <div><label class="block text-sm mb-1" style="color: var(--text-secondary);">背景图URL（留空使用默认渐变）</label><input id="backgroundUrl" type="text" class="service-input" placeholder="https://..." /></div>
        </div>
      </div>

      {/* ===== 侧边栏设置 ===== */}
      <div class="glass-card rounded-2xl p-6 animate-slide-up" style="animation-delay: 0.18s;">
        <h2 class="text-lg font-bold mb-4" style="color: var(--text-primary);">📐 侧边栏设置</h2>
        <div><label class="block text-sm mb-1" style="color: var(--text-secondary);">服务区块标题</label><input id="sidebarTitle" type="text" class="service-input" placeholder="Services" /></div>
      </div>

      {/* ===== Section 标题设置 ===== */}
      <div class="glass-card rounded-2xl p-6 animate-slide-up" style="animation-delay: 0.2s;">
        <h2 class="text-lg font-bold mb-4" style="color: var(--text-primary);">📊 区块标题设置</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div><label class="block text-sm mb-1" style="color: var(--text-secondary);">文章区标题</label><input id="sectionBlogsTitle" type="text" class="service-input" placeholder="Latest Blogs" /></div>
          <div>
            <label class="block text-sm mb-1" style="color: var(--text-secondary);">文章区竖条颜色</label>
            <select id="sectionBlogsBarColor" class="service-input">
              <option value="accent-1">强调色 1 (accent-1)</option>
              <option value="accent-2">强调色 2 (accent-2)</option>
              <option value="accent-1-light">强调色 1 亮</option>
              <option value="accent-2-light">强调色 2 亮</option>
            </select>
          </div>
          <div><label class="block text-sm mb-1" style="color: var(--text-secondary);">技术栈区标题</label><input id="sectionTechTitle" type="text" class="service-input" placeholder="Tech Stack" /></div>
          <div>
            <label class="block text-sm mb-1" style="color: var(--text-secondary);">技术栈区竖条颜色</label>
            <select id="sectionTechBarColor" class="service-input">
              <option value="accent-2">强调色 2 (accent-2)</option>
              <option value="accent-1">强调色 1 (accent-1)</option>
              <option value="accent-1-light">强调色 1 亮</option>
              <option value="accent-2-light">强调色 2 亮</option>
            </select>
          </div>
        </div>
      </div>

      {/* ===== 页脚设置 ===== */}
      <div class="glass-card rounded-2xl p-6 animate-slide-up" style="animation-delay: 0.23s;">
        <h2 class="text-lg font-bold mb-4" style="color: var(--text-primary);">🦶 页脚设置</h2>
        <div class="space-y-4">
          <div><label class="block text-sm mb-1" style="color: var(--text-secondary);">页脚渐变文字</label><input id="footerText" type="text" class="service-input" placeholder="Stay curious. Thanks for dropping by. 👋" /></div>
          <div><label class="block text-sm mb-1" style="color: var(--text-secondary);">技术徽章文字</label><input id="footerTechBadge" type="text" class="service-input" placeholder="Built with Astro 6" /></div>
        </div>
      </div>

      {/* ===== 侧边栏服务管理 ===== */}
      <div class="glass-card rounded-2xl p-6 animate-slide-up" style="animation-delay: 0.26s;">
        <h2 class="text-lg font-bold mb-4" style="color: var(--text-primary);">🔗 侧边栏服务管理</h2>
        <p class="text-sm mb-4" style="color: var(--text-muted);">自定义管理首页侧边栏中的服务链接</p>
        <div id="services-container" class="space-y-3"></div>
        <div class="mt-4 flex gap-3">
          <button onclick="addService()" class="ripple px-4 py-2 rounded-xl text-sm font-medium transition-all hover:bg-white/10 glass" style="color: var(--text-primary); border: 1px solid var(--glass-border);">➕ 添加服务</button>
        </div>
      </div>

      {/* ===== 自定义 CSS ===== */}
      <div class="glass-card rounded-2xl p-6 animate-slide-up" style="animation-delay: 0.29s;">
        <h2 class="text-lg font-bold mb-4" style="color: var(--text-primary);">🖌️ 自定义 CSS</h2>
        <p class="text-sm mb-3" style="color: var(--text-muted);">输入自定义 CSS 样式，会注入到首页中</p>
        <textarea id="customCss" class="service-input font-mono text-xs" rows="6" placeholder="/* 在这里输入自定义 CSS */"></textarea>
      </div>

      {/* ===== 保存按钮 ===== */}
      <div class="flex gap-4 animate-slide-up" style="animation-delay: 0.32s;">
        <button onclick="saveAll()" class="ripple px-6 py-2.5 rounded-xl text-sm font-semibold text-white bg-gradient-to-r from-purple-500 to-cyan-400 hover:opacity-90 transition-opacity">💾 保存所有设置</button>
        <button onclick="resetServices()" class="ripple px-4 py-2 rounded-xl text-sm font-medium transition-all glass" style="color: var(--text-muted); border: 1px solid var(--glass-border);">🔄 重置服务列表</button>
      </div>

      <div id="save-status" class="text-center text-sm py-2 hidden rounded-xl" style="color: var(--text-muted);"></div>
    </div>
  </div>
</Admin>

<script is:inline>
  let services = [];
  const defaultServices = [
    { icon: '🌐', title: 'Tunnel VPN', desc: '安全代理服务', url: 'https://cc.likegz.dpdns.org/admin', color: 'from-blue-500/20 to-cyan-500/20', copyable: true, copyUrl: '' },
    { icon: '🖼️', title: 'Telegraph 图床', desc: '高速图片托管', url: 'https://image.hiokt.dpdns.org', color: 'from-green-500/20 to-emerald-500/20' },
    { icon: '📺', title: 'MoonTV 影视', desc: '在线影视平台', url: 'https://moon.hiokt.dpdns.org', color: 'from-purple-500/20 to-pink-500/20' },
    { icon: '📋', title: 'SubTracker 订阅', desc: '订阅管理平台', url: 'https://sub.hiokt.dpdns.org', color: 'from-orange-500/20 to-yellow-500/20' },
  ];

  const colorOptions = [
    'from-blue-500/20 to-cyan-500/20','from-green-500/20 to-emerald-500/20',
    'from-purple-500/20 to-pink-500/20','from-orange-500/20 to-yellow-500/20',
    'from-red-500/20 to-rose-500/20','from-indigo-500/20 to-violet-500/20',
    'from-teal-500/20 to-cyan-500/20','from-amber-500/20 to-yellow-500/20',
  ];
  const iconOptions = ['🌐','🖼️','📺','📋','🔧','🎮','📡','🛡️','🎵','📁','🚀','💡'];

  async function loadSettings() {
    try {
      const token = localStorage.getItem('admin_token');
      const res = await fetch('/api/settings', { headers: { 'Authorization': 'Bearer ' + token } });
      const d = await res.json();
      document.getElementById('nickname').value = d.nickname || '';
      document.getElementById('qqNumber').value = d.qqNumber || '';
      document.getElementById('signature').value = d.signature || '';
      document.getElementById('avatarUrl').value = d.avatarUrl || '';
      document.getElementById('backgroundUrl').value = d.backgroundUrl || '';
      document.getElementById('heroTitle').value = d.heroTitle || '';
      document.getElementById('heroSubtitle').value = d.heroSubtitle || '';
      document.getElementById('heroDescription').value = d.heroDescription || '';
      document.getElementById('heroEmoji').value = d.heroEmoji || '👋';
      document.getElementById('heroTagline').value = d.heroTagline || '';
      document.getElementById('sidebarTitle').value = d.sidebarTitle || 'Services';
      document.getElementById('sectionBlogsTitle').value = d.sectionBlogsTitle || 'Latest Blogs';
      document.getElementById('sectionBlogsBarColor').value = d.sectionBlogsBarColor || 'accent-1';
      document.getElementById('sectionTechTitle').value = d.sectionTechTitle || 'Tech Stack';
      document.getElementById('sectionTechBarColor').value = d.sectionTechBarColor || 'accent-2';
      document.getElementById('footerText').value = d.footerText || '';
      document.getElementById('footerTechBadge').value = d.footerTechBadge || '';
      document.getElementById('customCss').value = d.customCss || '';
      try { services = JSON.parse(d.services || '[]'); } catch { services = [...defaultServices]; }
      if (services.length === 0) services = [...defaultServices];
      renderServices();
      updateAvatarPreview();
    } catch (e) { services = [...defaultServices]; renderServices(); }
  }

  function updateAvatarPreview() {
    const qq = document.getElementById('qqNumber').value;
    const url = document.getElementById('avatarUrl').value;
    document.getElementById('avatar-preview').src = url || 'https://q.qlogo.cn/g?b=qq&nk=' + qq + '&s=100';
  }

  function renderServices() {
    document.getElementById('services-container').innerHTML = services.map((s, i) => `
      <div class="service-item" data-index="${i}">
        <div class="flex items-center gap-2 min-w-0 flex-1">
          <div class="flex flex-col gap-1">
            <label class="text-[10px]" style="color: var(--text-muted);">图标</label>
            <select onchange="updateService(${i},'icon',this.value)" class="service-input w-14 text-center" style="padding:0.375rem;">
              ${iconOptions.map(icon => `<option value="${icon}" ${s.icon===icon?'selected':''}>${icon}</option>`).join('')}
            </select>
          </div>
          <div class="flex-1 min-w-0">
            <label class="text-[10px]" style="color: var(--text-muted);">标题</label>
            <input value="${s.title||''}" onchange="updateService(${i},'title',this.value)" class="service-input" />
          </div>
          <div class="flex-1 min-w-0">
            <label class="text-[10px]" style="color: var(--text-muted);">描述</label>
            <input value="${s.desc||''}" onchange="updateService(${i},'desc',this.value)" class="service-input" />
          </div>
        </div>
        <div class="flex flex-col gap-1" style="min-width:200px;">
          <label class="text-[10px]" style="color: var(--text-muted);">链接 URL</label>
          <input value="${s.url||''}" onchange="updateService(${i},'url',this.value)" class="service-input" placeholder="https://..." />
        </div>
        <div class="flex flex-col gap-1" style="min-width:200px;">
          <label class="text-[10px]" style="color: var(--text-muted);">复制按钮链接（留空则复制上方链接）</label>
          <input value="${s.copyUrl||''}" onchange="updateService(${i},'copyUrl',this.value)" class="service-input" placeholder="留空则复制主链接" />
        </div>
        <div class="flex items-center gap-2">
          <div class="flex flex-col gap-1">
            <label class="text-[10px]" style="color: var(--text-muted);">配色</label>
            <select onchange="updateService(${i},'color',this.value)" class="service-input w-10" style="padding:0.375rem;">
              ${colorOptions.map(c => `<option value="${c}" ${s.color===c?'selected':''}>●</option>`).join('')}
            </select>
          </div>
          <div class="flex flex-col gap-1">
            <label class="text-[10px]" style="color: var(--text-muted);">复制按钮</label>
            <button onclick="toggleCopyable(${i})" class="px-2 py-1 rounded text-[10px] font-medium transition-all ${s.copyable?'bg-green-500/20 text-green-400 border border-green-500/30':'glass'}">${s.copyable?'✅':'❌'}</button>
          </div>
          <button onclick="removeService(${i})" class="mt-4 px-2 py-1 rounded-lg bg-red-500/10 text-red-400 hover:bg-red-500/20 transition-all text-sm">🗑️</button>
        </div>
      </div>
    `).join('');
  }

  function updateService(i, field, val) { services[i][field] = val; }
  function toggleCopyable(i) { services[i].copyable = !services[i].copyable; renderServices(); }
  function addService() {
    services.push({ icon:'🌐', title:'新服务', desc:'描述', url:'https://', color: colorOptions[Math.floor(Math.random()*colorOptions.length)], copyable:false, copyUrl:'' });
    renderServices();
  }
  function removeService(i) { services.splice(i, 1); renderServices(); }
  function resetServices() { if (confirm('确定要重置服务列表为默认值吗？')) { services = [...defaultServices]; renderServices(); } }

  async function saveAll() {
    const st = document.getElementById('save-status');
    st.className = 'text-center text-sm py-2 rounded-xl';
    st.style.color = 'var(--text-muted)';
    st.textContent = '保存中...';
    st.classList.remove('hidden');
    try {
      const token = localStorage.getItem('admin_token');
      const body = {
        nickname: document.getElementById('nickname').value,
        qqNumber: document.getElementById('qqNumber').value,
        signature: document.getElementById('signature').value,
        avatarUrl: document.getElementById('avatarUrl').value,
        backgroundUrl: document.getElementById('backgroundUrl').value,
        heroTitle: document.getElementById('heroTitle').value,
        heroSubtitle: document.getElementById('heroSubtitle').value,
        heroDescription: document.getElementById('heroDescription').value,
        heroEmoji: document.getElementById('heroEmoji').value,
        heroTagline: document.getElementById('heroTagline').value,
        sidebarTitle: document.getElementById('sidebarTitle').value,
        sectionBlogsTitle: document.getElementById('sectionBlogsTitle').value,
        sectionBlogsBarColor: document.getElementById('sectionBlogsBarColor').value,
        sectionTechTitle: document.getElementById('sectionTechTitle').value,
        sectionTechBarColor: document.getElementById('sectionTechBarColor').value,
        footerText: document.getElementById('footerText').value,
        footerTechBadge: document.getElementById('footerTechBadge').value,
        customCss: document.getElementById('customCss').value,
        services: JSON.stringify(services),
      };
      const res = await fetch('/api/settings', { method:'PUT', headers:{'Content-Type':'application/json','Authorization':'Bearer '+token}, body: JSON.stringify(body) });
      if (res.ok) { st.textContent = '✅ 所有设置已保存！页面将在2秒后刷新...'; st.style.color = '#22c55e'; setTimeout(() => window.location.reload(), 2000); }
      else { st.textContent = '❌ 保存失败'; st.style.color = '#ef4444'; }
    } catch { st.textContent = '❌ 网络错误'; st.style.color = '#ef4444'; }
  }

  document.getElementById('qqNumber')?.addEventListener('input', updateAvatarPreview);
  document.getElementById('avatarUrl')?.addEventListener('input', updateAvatarPreview);
  loadSettings();
</script>

