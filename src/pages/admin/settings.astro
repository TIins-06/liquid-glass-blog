�---
export const prerender = false;
import Admin from '../../layouts/Admin.astro';
---

<Admin title="站点设置 | 管理后台">
  <div class="max-w-4xl mx-auto px-6">
    <div class="mb-8 animate-slide-up">
      <a href="/admin" class="text-sm mb-4 inline-block transition-colors hover:text-purple-400" style="color: var(--text-muted);">← 返回仪表盘</a>
      <h1 class="text-3xl font-bold" style="color: var(--text-primary);">⚙️ 站点设置</h1>
      <p class="mt-2" style="color: var(--text-secondary);">管理你的博客个性化配置，所有设置跨设备同步</p>
    </div>

    <div id="settings-form" class="space-y-6">
      {/* Profile Section */}
      <div class="glass-card rounded-2xl p-6 animate-slide-up" style="animation-delay: 0.1s;">
        <h2 class="text-lg font-bold mb-4" style="color: var(--text-primary);">👤 个人信息</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm mb-1" style="color: var(--text-secondary);">昵称</label>
            <input id="nickname" type="text" class="w-full px-4 py-2.5 rounded-xl text-sm" style="background: var(--glass-bg); border: 1px solid var(--glass-border); color: var(--text-primary);" />
          </div>
          <div>
            <label class="block text-sm mb-1" style="color: var(--text-secondary);">QQ号</label>
            <input id="qqNumber" type="text" class="w-full px-4 py-2.5 rounded-xl text-sm" style="background: var(--glass-bg); border: 1px solid var(--glass-border); color: var(--text-primary);" />
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm mb-1" style="color: var(--text-secondary);">个性签名</label>
            <input id="signature" type="text" class="w-full px-4 py-2.5 rounded-xl text-sm" style="background: var(--glass-bg); border: 1px solid var(--glass-border); color: var(--text-primary);" />
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm mb-1" style="color: var(--text-secondary);">头像URL（留空则使用QQ头像）</label>
            <input id="avatarUrl" type="text" class="w-full px-4 py-2.5 rounded-xl text-sm" placeholder="https://..." style="background: var(--glass-bg); border: 1px solid var(--glass-border); color: var(--text-primary);" />
          </div>
        </div>
        {/* Avatar Preview */}
        <div class="mt-4 flex items-center gap-4">
          <div class="w-16 h-16 rounded-full p-0.5 bg-gradient-to-br from-purple-500 to-cyan-400">
            <img id="avatar-preview" src="" class="w-full h-full rounded-full object-cover" alt="avatar" />
          </div>
          <span class="text-sm" style="color: var(--text-muted);">头像预览</span>
        </div>
      </div>

      {/* Appearance Section */}
      <div class="glass-card rounded-2xl p-6 animate-slide-up" style="animation-delay: 0.2s;">
        <h2 class="text-lg font-bold mb-4" style="color: var(--text-primary);">🎨 外观设置</h2>
        <div class="space-y-4">
          <div>
            <label class="block text-sm mb-1" style="color: var(--text-secondary);">背景图URL（留空使用默认渐变）</label>
            <input id="backgroundUrl" type="text" class="w-full px-4 py-2.5 rounded-xl text-sm" placeholder="https://..." style="background: var(--glass-bg); border: 1px solid var(--glass-border); color: var(--text-primary);" />
          </div>
          <div>
            <label class="block text-sm mb-1" style="color: var(--text-secondary);">主题</label>
            <select id="theme" class="w-full px-4 py-2.5 rounded-xl text-sm" style="background: var(--glass-bg); border: 1px solid var(--glass-border); color: var(--text-primary);">
              <option value="dark">暗色</option>
              <option value="light">亮色</option>
            </select>
          </div>
          <div class="flex items-center gap-3">
            <input id="animations" type="checkbox" class="w-4 h-4 rounded" />
            <label for="animations" class="text-sm" style="color: var(--text-secondary);">启用动效</label>
          </div>
        </div>
      </div>

      {/* Hero Section */}
      <div class="glass-card rounded-2xl p-6 animate-slide-up" style="animation-delay: 0.3s;">
        <h2 class="text-lg font-bold mb-4" style="color: var(--text-primary);">🏠 首页设置</h2>
        <div class="space-y-4">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm mb-1" style="color: var(--text-secondary);">标题</label>
              <input id="heroTitle" type="text" class="w-full px-4 py-2.5 rounded-xl text-sm" style="background: var(--glass-bg); border: 1px solid var(--glass-border); color: var(--text-primary);" />
            </div>
            <div>
              <label class="block text-sm mb-1" style="color: var(--text-secondary);">副标题</label>
              <input id="heroSubtitle" type="text" class="w-full px-4 py-2.5 rounded-xl text-sm" style="background: var(--glass-bg); border: 1px solid var(--glass-border); color: var(--text-primary);" />
            </div>
          </div>
          <div>
            <label class="block text-sm mb-1" style="color: var(--text-secondary);">描述</label>
            <input id="heroDescription" type="text" class="w-full px-4 py-2.5 rounded-xl text-sm" style="background: var(--glass-bg); border: 1px solid var(--glass-border); color: var(--text-primary);" />
          </div>
        </div>
      </div>

      {/* Security Section */}
      <div class="glass-card rounded-2xl p-6 animate-slide-up" style="animation-delay: 0.4s;">
        <h2 class="text-lg font-bold mb-4" style="color: var(--text-primary);">🔒 安全设置</h2>
        <div>
          <label class="block text-sm mb-1" style="color: var(--text-secondary);">管理员密码</label>
          <input id="adminPassword" type="password" class="w-full px-4 py-2.5 rounded-xl text-sm" style="background: var(--glass-bg); border: 1px solid var(--glass-border); color: var(--text-primary);" />
          <p class="text-xs mt-1" style="color: var(--text-muted);">留空则不修改密码</p>
        </div>
      </div>

      {/* Save Button */}
      <div class="flex justify-end animate-slide-up" style="animation-delay: 0.5s;">
        <button id="save-btn" onclick="saveSettings()" class="ripple px-8 py-3 rounded-xl text-sm font-semibold text-white bg-gradient-to-r from-purple-500 to-cyan-400 hover:opacity-90 transition-opacity">
          💾 保存设置
        </button>
      </div>

      {/* Status */}
      <div id="save-status" class="text-center text-sm hidden" style="color: var(--text-muted);"></div>
    </div>
  </div>
</Admin>

<script is:inline>
  (function() {
    // Check auth
    if (!localStorage.getItem('admin_token')) {
      window.location.href = '/admin/login';
      return;
    }

    // Load current settings
    fetch('/api/settings')
      .then(r => r.json())
      .then(data => {
        document.getElementById('nickname').value = data.nickname || '';
        document.getElementById('qqNumber').value = data.qqNumber || '';
        document.getElementById('signature').value = data.signature || '';
        document.getElementById('avatarUrl').value = data.avatarUrl || '';
        document.getElementById('backgroundUrl').value = data.backgroundUrl || '';
        document.getElementById('theme').value = data.theme || 'dark';
        document.getElementById('animations').checked = data.animations !== false && data.animations !== 'off';
        document.getElementById('heroTitle').value = data.heroTitle || '';
        document.getElementById('heroSubtitle').value = data.heroSubtitle || '';
        document.getElementById('heroDescription').value = data.heroDescription || '';
        // Avatar preview
        updateAvatarPreview();
      });

    // Avatar preview on QQ number change
    document.getElementById('qqNumber').addEventListener('input', updateAvatarPreview);
  })();

  function updateAvatarPreview() {
    var qq = document.getElementById('qqNumber').value.trim();
    var customUrl = document.getElementById('avatarUrl').value.trim();
    var url = customUrl || (qq ? 'https://q.qlogo.cn/g?b=qq&nk=' + qq + '&s=100' : '');
    if (url) document.getElementById('avatar-preview').src = url;
  }

  function saveSettings() {
    var btn = document.getElementById('save-btn');
    var status = document.getElementById('save-status');
    btn.disabled = true;
    btn.textContent = '保存中...';
    status.className = 'text-center text-sm';
    status.style.color = 'var(--text-muted)';
    status.textContent = '正在保存...';

    var data = {
      nickname: document.getElementById('nickname').value,
      qqNumber: document.getElementById('qqNumber').value,
      signature: document.getElementById('signature').value,
      avatarUrl: document.getElementById('avatarUrl').value,
      backgroundUrl: document.getElementById('backgroundUrl').value,
      theme: document.getElementById('theme').value,
      animations: document.getElementById('animations').checked ? 'true' : 'false',
      heroTitle: document.getElementById('heroTitle').value,
      heroSubtitle: document.getElementById('heroSubtitle').value,
      heroDescription: document.getElementById('heroDescription').value,
    };

    var pw = document.getElementById('adminPassword').value.trim();
    if (pw) data.adminPassword = pw;

    fetch('/api/settings', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    })
    .then(r => r.json())
    .then(result => {
      if (result.ok) {
        status.textContent = '✅ 设置已保存并同步到所有设备';
        status.style.color = '#22c55e';
        document.getElementById('adminPassword').value = '';
      } else {
        status.textContent = '❌ 保存失败: ' + (result.error || '未知错误');
        status.style.color = '#ef4444';
      }
    })
    .catch(err => {
      status.textContent = '❌ 网络错误: ' + err.message;
      status.style.color = '#ef4444';
    })
    .finally(() => {
      btn.disabled = false;
      btn.textContent = '💾 保存设置';
      setTimeout(() => { status.className = 'text-center text-sm hidden'; }, 5000);
    });
  }
</script>

