---
export const prerender = false;
import Admin from '../../layouts/Admin.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Admin title="文章管理 | 管理后台">
  <div class="max-w-4xl mx-auto px-6">
    <div class="mb-8 animate-slide-up">
      <a href="/admin" class="text-sm mb-4 inline-block transition-colors hover:text-purple-400" style="color: var(--text-muted);">← 返回仪表盘</a>
      <h1 class="text-3xl font-bold" style="color: var(--text-primary);">📝 文章管理</h1>
      <p class="mt-2" style="color: var(--text-secondary);">共 {posts.length} 篇文章</p>
    </div>

    <div class="space-y-3">
      {posts.map((post, i) => (
        <div class="glass-card rounded-xl p-5 flex items-center justify-between animate-slide-up" style={`animation-delay: ${i * 0.05}s;`}>
          <div class="flex-1 min-w-0 mr-4">
            <div class="flex items-center gap-2 mb-1">
              <h3 class="text-sm font-bold truncate" style="color: var(--text-primary);">{post.data.title}</h3>
              {post.data.tags.slice(0, 2).map(tag => (
                <span class="text-[10px] px-2 py-0.5 rounded-full bg-purple-500/20 text-purple-300 shrink-0">{tag}</span>
              ))}
            </div>
            <p class="text-xs truncate" style="color: var(--text-muted);">{post.data.description}</p>
            <p class="text-[10px] mt-1" style="color: var(--text-muted);">{post.data.date.toLocaleDateString('zh-CN')} · src/content/blog/{post.id}.mdx</p>
          </div>
          <div class="flex items-center gap-2 shrink-0">
            <a href={`/blog/${post.id}`} target="_blank" class="text-xs px-3 py-1.5 rounded-lg glass transition-all hover:bg-white/10" style="color: var(--text-secondary); border: 1px solid var(--glass-border);">
              查看
            </a>
          </div>
        </div>
      ))}
    </div>

    {posts.length === 0 && (
      <div class="text-center py-20">
        <p class="text-lg" style="color: var(--text-muted);">暂无文章</p>
        <p class="text-sm mt-2" style="color: var(--text-muted);">在 src/content/blog/ 目录下创建 .mdx 文件来发布新文章</p>
      </div>
    )}

    <div class="mt-8 glass-card rounded-xl p-5 animate-slide-up" style="animation-delay: 0.5s;">
      <h3 class="text-sm font-bold mb-2" style="color: var(--text-primary);">💡 发布新文章</h3>
      <p class="text-xs" style="color: var(--text-secondary);">
        在 <code class="px-1.5 py-0.5 rounded" style="background: var(--glass-bg);">src/content/blog/</code> 目录下创建 <code class="px-1.5 py-0.5 rounded" style="background: var(--glass-bg);">.mdx</code> 文件，使用以下 frontmatter 格式：
      </p>
      <pre class="mt-3 p-3 rounded-lg text-xs overflow-x-auto" style="background: rgba(0,0,0,0.3); color: var(--text-secondary);">---
title: "文章标题"
description: "文章描述"
date: 2026-06-06
tags: ["标签1", "标签2"]
---

文章内容使用 Markdown/MDX 语法编写。</pre>
    </div>
  </div>
</Admin>

<script is:inline>
  (function() {
    if (!localStorage.getItem('admin_token')) {
      window.location.href = '/admin/login';
    }
  })();
</script>

