---
export const prerender = false;
import Admin from '../../layouts/Admin.astro';
---

<Admin title="文章管理 | 管理后台">
  <div class="max-w-4xl mx-auto px-6">
    <div class="mb-8 animate-slide-up">
      <a href="/admin" class="text-sm mb-4 inline-block transition-colors hover:text-purple-400" style="color: var(--text-muted);">← 返回仪表盘</a>
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-3xl font-bold" style="color: var(--text-primary);">📝 文章管理</h1>
          <p class="mt-2" style="color: var(--text-secondary);">共 <span id="article-count">0</span> 篇文章</p>
        </div>
        <a href="/admin/editor" class="px-4 py-2 rounded-xl text-sm font-medium text-white transition-all hover:scale-105" style="background: linear-gradient(135deg, var(--accent-1), var(--accent-2)); box-shadow: 0 4px 15px rgba(124,58,237,0.3);">
          ✏️ 写文章
        </a>
      </div>
    </div>

    <div id="articles-list" class="space-y-3"></div>
    <div id="articles-loading" class="text-center py-20">
      <p style="color: var(--text-muted);">加载中...</p>
    </div>
    <div id="articles-empty" class="text-center py-20 hidden">
      <p class="text-lg" style="color: var(--text-muted);">暂无文章</p>
      <p class="text-sm mt-2" style="color: var(--text-muted);">点击上方「写文章」按钮发布新文章</p>
    </div>
  </div>

  <script is:inline>
    (function() {
      if (!localStorage.getItem('admin_token')) {
        window.location.href = '/admin/login';
        return;
      }

      function escH(s) { return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

      function renderArticles(articles) {
        var list = document.getElementById('articles-list');
        var loading = document.getElementById('articles-loading');
        var empty = document.getElementById('articles-empty');
        loading.classList.add('hidden');

        if (!articles || articles.length === 0) {
          empty.classList.remove('hidden');
          return;
        }

        document.getElementById('article-count').textContent = articles.length;

        list.innerHTML = articles.map(function(a, i) {
          var tags = (a.tags || []).slice(0, 3).map(function(t) {
            return '<span class="text-[10px] px-2 py-0.5 rounded-full" style="background:rgba(124,58,237,0.15);color:var(--accent-1-light);">' + escH(t) + '</span>';
          }).join('');
          var dateStr = a.date || '';
          var source = a.source === 'static' ? ' · <span style="color:var(--accent-2-light);">静态</span>' : ' · <span style="color:var(--accent-1-light);">动态</span>';
          var draftBadge = a.draft ? '<span class="text-[10px] px-2 py-0.5 rounded-full" style="background:rgba(245,158,11,0.15);color:#fbbf24;">草稿</span>' : '';

          return '<div class="rounded-xl p-5 flex items-center justify-between animate-slide-up" style="animation-delay:' + (i * 0.03) + 's;background:var(--glass-bg);border:1px solid var(--glass-border);backdrop-filter:blur(var(--card-blur)) saturate(150%);-webkit-backdrop-filter:blur(var(--card-blur)) saturate(150%);">' +
            '<div class="flex-1 min-w-0 mr-4">' +
              '<div class="flex items-center gap-2 mb-1 flex-wrap">' +
                '<h3 class="text-sm font-bold truncate" style="color:var(--text-primary);">' + escH(a.title) + '</h3>' +
                draftBadge + tags +
              '</div>' +
              '<p class="text-xs truncate" style="color:var(--text-muted);">' + escH(a.description || '') + '</p>' +
              '<p class="text-[10px] mt-1" style="color:var(--text-muted);">' + dateStr + source + '</p>' +
            '</div>' +
            '<div class="flex items-center gap-2 shrink-0">' +
              '<a href="/blog/' + (a.source === 'static' ? '' : 'kv/') + escH(a.slug) + '" target="_blank" class="text-xs px-3 py-1.5 rounded-lg transition-all hover:bg-white/10" style="color:var(--text-secondary);border:1px solid var(--glass-border);">查看</a>' +
              '<a href="/admin/editor?slug=' + encodeURIComponent(a.slug) + '" class="text-xs px-3 py-1.5 rounded-lg transition-all hover:bg-blue-500/20" style="color:#60a5fa;border:1px solid rgba(96,165,250,0.3);">编辑</a>' +
              '<button onclick="deleteArticle(\'' + escH(a.slug) + '\')" class="text-xs px-3 py-1.5 rounded-lg transition-all hover:bg-red-500/20" style="color:#f87171;border:1px solid rgba(248,113,113,0.3);">删除</button>' +
            '</div>' +
          '</div>';
        }).join('');
      }

      // Load articles
      fetch('/api/articles').then(function(r) { return r.json(); }).then(function(data) {
        renderArticles(data);
      }).catch(function() {
        document.getElementById('articles-loading').innerHTML = '<p style="color:#f87171;">加载失败</p>';
      });

      window.deleteArticle = function(slug) {
        if (!confirm('确定删除文章「' + slug + '」？此操作不可撤销。')) return;
        fetch('/api/articles/manage?slug=' + encodeURIComponent(slug), { method: 'DELETE' })
          .then(function(r) { return r.json(); })
          .then(function(d) {
            if (d.ok) {
              // Remove from DOM
              var list = document.getElementById('articles-list');
              var items = list.children;
              for (var i = items.length - 1; i >= 0; i--) {
                if (items[i].innerHTML.includes('slug=' + encodeURIComponent(slug))) {
                  items[i].remove();
                }
              }
              var count = document.getElementById('article-count');
              count.textContent = parseInt(count.textContent) - 1;
              if (list.children.length === 0) {
                document.getElementById('articles-empty').classList.remove('hidden');
              }
            } else {
              alert('删除失败: ' + (d.error || '未知错误'));
            }
          })
          .catch(function() { alert('网络错误'); });
      };
    })();
  </script>
</Admin>

