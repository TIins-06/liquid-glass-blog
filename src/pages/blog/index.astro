---
import Base from '../../layouts/Base.astro';
import GlassCard from '../../components/glass/GlassCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))];
---

<Base title="文章 | 液态玻璃 Blog" description="浏览所有博客文章">
  <section class="max-w-6xl mx-auto px-6 py-12">
    <h1 class="text-3xl md:text-4xl font-extrabold mb-4 animate-slide-up">
      <span class="text-gradient">全部文章</span>
    </h1>
    <p class="mb-8 animate-slide-up" style="color: var(--text-secondary); animation-delay: 0.1s;">
      共 {posts.length} 篇文章
    </p>

    {/* Tag Filter */}
    <div class="flex flex-wrap gap-2 mb-10 animate-slide-up" style="animation-delay: 0.2s;">
      <button
        class="tag-filter ripple glass px-3 py-1 rounded-full text-xs font-medium transition-all text-purple-300 border-purple-500/30"
        data-tag="all"
      >
        全部
      </button>
      {allTags.map((tag) => (
        <button
          class="tag-filter ripple glass px-3 py-1 rounded-full text-xs font-medium transition-all"
          style="color: var(--text-muted)"
          data-tag={tag}
        >
          {tag}
        </button>
      ))}
    </div>

    {/* Posts Grid */}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="posts-grid">
      {posts.map((post, i) => (
        <a
          href={`/blog/${post.id}`}
          class="post-card block group animate-slide-up"
          data-tags={post.data.tags.join(',')}
          style={`animation-delay: ${0.1 * i}s`}
        >
          <GlassCard class="h-full">
            <div class="flex items-center gap-2 mb-3">
              {post.data.tags.slice(0, 2).map((tag) => (
                <span class="text-xs px-2 py-0.5 rounded-full bg-purple-500/20 text-purple-300">
                  {tag}
                </span>
              ))}
            </div>
            <h2 class="text-lg font-bold mb-2 group-hover:text-purple-400 transition-colors" style="color: var(--text-primary);">
              {post.data.title}
            </h2>
            <p class="text-sm mb-4 line-clamp-2" style="color: var(--text-secondary);">
              {post.data.description}
            </p>
            <div class="text-xs" style="color: var(--text-muted);">
              {post.data.date.toLocaleDateString('zh-CN')}
            </div>
          </GlassCard>
        </a>
      ))}
    </div>

    {posts.length === 0 && (
      <div class="text-center py-20">
        <p class="text-lg" style="color: var(--text-muted);">暂无文章</p>
      </div>
    )}
  </section>
</Base>

<script>
  document.querySelectorAll('.tag-filter').forEach((btn) => {
    btn.addEventListener('click', () => {
      const tag = btn.getAttribute('data-tag');
      document.querySelectorAll('.tag-filter').forEach((b) => {
        b.classList.remove('text-purple-300', 'border-purple-500/30');
        b.style.color = 'var(--text-muted)';
      });
      btn.classList.add('text-purple-300');
      btn.classList.remove('text-[color:var(--text-muted)]');

      document.querySelectorAll('.post-card').forEach((card) => {
        const cardTags = card.getAttribute('data-tags') || '';
        if (tag === 'all' || cardTags.includes(tag)) {
          (card as HTMLElement).style.display = '';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>

