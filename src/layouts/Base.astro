---
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
import SettingsPanel from '../components/interactive/SettingsPanel.tsx';
import MusicPlayer from '../components/interactive/MusicPlayer.tsx';
import CursorEffect from '../components/interactive/CursorEffect.tsx';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = '液态玻璃 | Liquid Glass Blog',
  description = '一个充满玻璃质感与动效的现代博客',
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#7c3aed" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen">
    <CursorEffect client:load />
    <Navbar />
    <main class="pt-20 min-h-screen">
      <slot />
    </main>
    <Footer />
    <SettingsPanel client:load />
    <MusicPlayer client:load />
    <script is:inline>
      (function () {
        const theme = localStorage.getItem('theme') || 'dark';
        document.documentElement.setAttribute('data-theme', theme);
        const animations = localStorage.getItem('animations');
        if (animations === 'off') {
          document.documentElement.setAttribute('data-no-animations', '');
        }
        const color = localStorage.getItem('color-preset') || 'purple';
        document.documentElement.setAttribute('data-color', color);
      })();
    </script>
  </body>
</html>



