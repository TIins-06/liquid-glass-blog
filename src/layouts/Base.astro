---
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
import SettingsPanel from '../components/interactive/SettingsPanel.tsx';
import MusicPlayer from '../components/interactive/MusicPlayer.tsx';
import CursorEffect from '../components/interactive/CursorEffect.tsx';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = '液态玻璃 | Liquid Glass Blog',
  description = '一个充满玻璃质感与动效的现代博客',
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN" data-theme="dark" data-color="purple">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#7c3aed" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen">
    <CursorEffect client:load />
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
    <SettingsPanel client:load />
    <MusicPlayer client:load />
    <script is:inline>
      (function () {
        const theme = localStorage.getItem('theme') || 'dark';
        document.documentElement.setAttribute('data-theme', theme);
        const animations = localStorage.getItem('animations');
        if (animations === 'off') {
          document.documentElement.setAttribute('data-no-animations', '');
        }
        const color = localStorage.getItem('color-preset') || 'purple';
        document.documentElement.setAttribute('data-color', color);

        // Fetch background from API (cross-device setting)
        fetch('/api/settings').then(function(r) { return r.json(); }).then(function(data) {
          if (data && data.backgroundUrl) {
            document.body.style.backgroundImage = 'url(' + data.backgroundUrl + ')';
            document.body.style.backgroundSize = 'cover';
            document.body.style.backgroundPosition = 'center';
            document.body.style.backgroundAttachment = 'fixed';
          }
        }).catch(function() {});

        // Apply saved style preset
        const style = localStorage.getItem('style-preset') || 'default';
        const styleValues = {
          default: { radius: '20px', frostBlur: '0px', tint: 'rgba(255,255,255,0.16)', innerBlur: '20px', innerSpread: '-5px' },
          frosted: { radius: '20px', frostBlur: '0px', tint: 'rgba(255,255,255,0.12)', innerBlur: '12px', innerSpread: '-3px' },
          crystal: { radius: '28px', frostBlur: '0px', tint: 'rgba(255,255,255,0.2)', innerBlur: '24px', innerSpread: '-8px' },
          minimal: { radius: '12px', frostBlur: '0px', tint: 'rgba(255,255,255,0.08)', innerBlur: '8px', innerSpread: '-2px' },
          pill: { radius: '100px', frostBlur: '0px', tint: 'rgba(255,255,255,0.18)', innerBlur: '16px', innerSpread: '-4px' },
        };
        const sv = styleValues[style] || styleValues.default;
        const root = document.documentElement;
        root.style.setProperty('--lg-radius', sv.radius);
        root.style.setProperty('--frost-blur', sv.frostBlur);
        root.style.setProperty('--glass-tint', sv.tint);
        root.style.setProperty('--inner-blur', sv.innerBlur);
        root.style.setProperty('--inner-spread', sv.innerSpread);
      })();
    </script>
  </body>
</html>