---
const navLinks = [
  { href: '/', label: 'Home', icon: '🏠' },
  { href: '/blog', label: 'Blog', icon: '📝' },
  { href: '/tags', label: 'Tags', icon: '🏷️' },
];

const currentPath = Astro.url.pathname;
---

<div
  id="navbar"
  class="fixed z-50 flex inset-x-0 top-4 mx-auto items-center justify-between rounded-2xl glass-strong px-3 sm:px-5 transition-all duration-300"
  style="height: 52px; max-width: 640px;"
>
  <nav class="flex items-center gap-0.5 sm:gap-1">
    <a href="/" class="flex items-center gap-2 px-3 py-2 rounded-xl hover:bg-white/5 transition-all group">
      <span class="w-6 h-6 rounded-lg bg-gradient-to-br from-[var(--accent-1)] to-[var(--accent-2)] flex items-center justify-center text-white font-bold text-[10px] shadow-sm group-hover:scale-110 transition-transform">L</span>
      <span class="font-semibold text-sm text-gradient hidden sm:block">Liquid Glass</span>
    </a>
    {navLinks.map((link) => (
      <a
        href={link.href}
        class={`flex items-center gap-1.5 px-3 py-2 rounded-xl text-sm font-medium transition-all ${
          currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
            ? 'bg-white/10 text-white'
            : 'text-[color:var(--text-secondary)] hover:text-[color:var(--text-primary)] hover:bg-white/5'
        }`}
      >
        <span class="text-sm">{link.icon}</span>
        <span class="hidden sm:inline">{link.label}</span>
      </a>
    ))}
  </nav>

  <div class="flex items-center gap-1 relative" id="nav-right">
    {/* Single unified settings button with dropdown */}
    <button
      id="nav-settings-btn" type="button"
      class="flex items-center gap-1.5 px-3 py-2 rounded-xl text-sm font-medium transition-all text-[color:var(--text-secondary)] hover:text-[color:var(--text-primary)] hover:bg-white/5"
      aria-label="设置"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path>
        <circle cx="12" cy="12" r="3"></circle>
      </svg>
      <svg id="nav-chevron" class="w-3 h-3 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
    </button>

    {/* Dropdown Menu */}
    <div id="nav-dropdown" class="absolute top-full right-0 mt-2 w-44 rounded-xl shadow-xl overflow-hidden hidden z-50" style="background: var(--bg-secondary); border: 1px solid var(--glass-border); backdrop-filter: blur(20px);">
      <a href="/admin" class="flex items-center gap-2 px-4 py-2.5 text-sm transition-all hover:bg-white/5" style="color: var(--text-secondary);">
        <span>⚙️</span>
        <span>管理后台</span>
      </a>
      <button id="nav-settings-toggle" class="w-full flex items-center gap-2 px-4 py-2.5 text-sm transition-all hover:bg-white/5 text-left" style="color: var(--text-secondary);">
        <span>🎨</span>
        <span>外观设置</span>
      </button>
    </div>
  </div>
</div>

<script>
  // Scroll-based navbar styling
  window.addEventListener('scroll', () => {
    const navbar = document.getElementById('navbar');
    if (!navbar) return;
    if (window.scrollY > 50) {
      navbar.classList.add('bg-background/80');
    } else {
      navbar.classList.remove('bg-background/80');
    }
  });

  // Dropdown toggle
  const settingsBtn = document.getElementById('nav-settings-btn');
  const dropdown = document.getElementById('nav-dropdown');
  const chevron = document.getElementById('nav-chevron');
  
  settingsBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = !dropdown?.classList.contains('hidden');
    dropdown?.classList.toggle('hidden');
    chevron?.style.setProperty('transform', isOpen ? '' : 'rotate(180deg)');
  });

  // Close dropdown on outside click
  document.addEventListener('click', (e) => {
    const navRight = document.getElementById('nav-right');
    if (navRight && !navRight.contains(e.target as Node)) {
      dropdown?.classList.add('hidden');
      chevron?.style.setProperty('transform', '');
    }
  });

  // Settings toggle (opens SettingsPanel)
  document.getElementById('nav-settings-toggle')?.addEventListener('click', () => {
    dropdown?.classList.add('hidden');
    chevron?.style.setProperty('transform', '');
    window.dispatchEvent(new CustomEvent('toggle-settings'));
  });
</script>
