---
const navLinks = [
  { href: '/', label: 'Home', icon: '🏠' },
  { href: '/blog', label: 'Blog', icon: '📝' },
  { href: '/tags', label: 'Tags', icon: '🏷️' },
];
const currentPath = Astro.url.pathname;
---

<div
  id="navbar"
  class="lg-capsule fixed z-50 flex inset-x-0 top-3 mx-auto items-center justify-between px-3 sm:px-4"
  style="height: 44px; max-width: 600px;"
>
  <nav class="flex items-center gap-0.5 sm:gap-1">
    <a href="/" class="flex items-center gap-1.5 px-2 py-1.5 rounded-full hover:bg-white/5 transition-all group">
      <span class="w-6 h-6 rounded-lg bg-gradient-to-br from-[var(--accent-1)] to-[var(--accent-2)] flex items-center justify-center text-white font-bold text-[10px] shadow-sm group-hover:scale-110 transition-transform">L</span>
      <span class="font-semibold text-sm text-gradient hidden sm:block">Liquid Glass</span>
    </a>
    {navLinks.map((link) => (
      <a
        href={link.href}
        class:list={[
          'lg-capsule ripple flex items-center gap-1 px-2.5 py-1.5 text-xs font-medium transition-all',
          currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
            ? 'nav-active'
            : 'nav-inactive'
        ]}
      >
        <span class="text-xs">{link.icon}</span>
        <span class="hidden sm:inline">{link.label}</span>
      </a>
    ))}
  </nav>

  <div class="flex items-center gap-1 relative" id="nav-right">
    <div class="nav-search-wrap" id="nav-search-wrap">
      <button id="nav-search-toggle" type="button" class="lg-capsule ripple flex items-center gap-1 px-2.5 py-1.5 text-xs font-medium nav-inactive" aria-label="搜索">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </button>
      <div id="nav-search-panel" class="nav-search-panel hidden">
        <input id="nav-search-input" type="text" placeholder="搜索歌曲..." class="nav-search-input" onkeydown="if(event.key==='Enter')navDoSearch()" />
        <div id="nav-search-results" class="nav-search-results"></div>
      </div>
    </div>

    <button
      id="nav-settings-btn" type="button"
      class="lg-capsule ripple flex items-center gap-1 px-2.5 py-1.5 text-xs font-medium nav-inactive"
      aria-label="设置"
      onclick="window.dispatchEvent(new CustomEvent('toggle-settings'))"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path>
        <circle cx="12" cy="12" r="3"></circle>
      </svg>
    </button>
  </div>
</div>

<style>
  .nav-active {
    background: linear-gradient(135deg, var(--accent-1), var(--accent-2)) !important;
    color: white !important;
  }
  [data-theme="light"] .nav-active { color: white !important; }
  .nav-inactive { color: var(--text-secondary); }
  .nav-inactive:hover { color: var(--text-primary); }

  .nav-search-wrap { position: relative; }
  .nav-search-panel {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    width: 260px;
    border-radius: var(--card-radius);
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    backdrop-filter: blur(var(--card-blur)) saturate(150%);
    -webkit-backdrop-filter: blur(var(--card-blur)) saturate(150%);
    box-shadow: 0 12px 40px -8px rgba(0,0,0,0.3);
    padding: 0.5rem;
    z-index: 60;
    animation: slide-up 0.2s ease;
  }
  [data-theme="light"] .nav-search-panel {
    background: rgba(255,255,255,0.85);
    box-shadow: 0 12px 40px -8px rgba(0,0,0,0.1);
  }
  .nav-search-input {
    width: 100%;
    padding: 0.5rem 0.75rem;
    border-radius: 0.625rem;
    font-size: 0.75rem;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    color: var(--text-primary);
    outline: none;
  }
  [data-theme="light"] .nav-search-input { background: rgba(0,0,0,0.03); border-color: rgba(0,0,0,0.12); }
  .nav-search-input:focus { border-color: var(--accent-1); }
  .nav-search-input::placeholder { color: var(--text-muted); }
  .nav-search-results {
    max-height: 280px;
    overflow-y: auto;
    margin-top: 0.375rem;
  }
  .nav-search-results::-webkit-scrollbar { width: 3px; }
  .nav-search-results::-webkit-scrollbar-thumb { background: var(--glass-border); border-radius: 100px; }
  .nsr-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.5rem;
    border-radius: 0.5rem;
    cursor: pointer;
    transition: background 0.15s;
  }
  .nsr-item:hover { background: rgba(255,255,255,0.08); }
  .nsr-item .nsr-art {
    width: 2rem; height: 2rem;
    border-radius: 0.375rem;
    background: linear-gradient(135deg, var(--accent-1), var(--accent-2));
    display: flex; align-items: center; justify-content: center;
    font-size: 0.7rem; flex-shrink: 0; overflow: hidden;
  }
  .nsr-item .nsr-art img { width: 100%; height: 100%; object-fit: cover; }
  .nsr-item .nsr-info { flex: 1; min-width: 0; }
  .nsr-item .nsr-title { font-size: 0.7rem; font-weight: 500; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .nsr-item .nsr-artist { font-size: 0.6rem; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .nsr-item .nsr-play {
    width: 1.5rem; height: 1.5rem;
    border-radius: 50%; border: none;
    background: linear-gradient(135deg, var(--accent-1), var(--accent-2));
    color: white; font-size: 0.5rem;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; flex-shrink: 0; opacity: 0; transition: opacity 0.15s;
  }
  .nsr-item:hover .nsr-play { opacity: 1; }
  .nsr-status { text-align: center; padding: 0.5rem; font-size: 0.65rem; color: var(--text-muted); }
</style>

<script>
  // Scroll shadow
  window.addEventListener('scroll', () => {
    const navbar = document.getElementById('navbar');
    if (!navbar) return;
    navbar.style.boxShadow = window.scrollY > 50 ? '0 8px 32px -8px rgba(0,0,0,0.4), 0 0 0 1px rgba(255,255,255,0.12) inset' : '';
  });

  // Search toggle
  const searchToggle = document.getElementById('nav-search-toggle');
  const searchPanel = document.getElementById('nav-search-panel');
  searchToggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    searchPanel?.classList.toggle('hidden');
    if (!searchPanel?.classList.contains('hidden')) {
      document.getElementById('nav-search-input')?.focus();
    }
  });
  document.addEventListener('click', (e) => {
    const wrap = document.getElementById('nav-search-wrap');
    if (wrap && !wrap.contains(e.target as Node)) {
      searchPanel?.classList.add('hidden');
    }
  });

  // Search function
  (window as any).navDoSearch = async function() {
    const input = document.getElementById('nav-search-input') as HTMLInputElement;
    const results = document.getElementById('nav-search-results');
    const q = input?.value?.trim();
    if (!q || !results) return;
    results.innerHTML = '<div class="nsr-status">搜索中...</div>';
    try {
      const resp = await fetch('/api/music/search?q=' + encodeURIComponent(q));
      const data = await resp.json();
      const songs = data.songs || [];
      if (songs.length === 0) {
        results.innerHTML = '<div class="nsr-status">未找到结果</div>';
        return;
      }
      results.innerHTML = songs.slice(0, 8).map((s: any) => {
        const art = s.cover
          ? `<img src="${s.cover}" onerror="this.parentElement.textContent='🎵'" />`
          : '🎵';
        return `<div class="nsr-item" onclick="navPlaySong('${s.src.replace(/'/g,"\\'")}','${s.title.replace(/'/g,"\\'")}','${s.artist.replace(/'/g,"\\'")}')">
          <div class="nsr-art">${art}</div>
          <div class="nsr-info"><div class="nsr-title">${escH(s.title)}</div><div class="nsr-artist">${escH(s.artist)}</div></div>
          <button class="nsr-play">▶</button>
        </div>`;
      }).join('');
    } catch {
      results.innerHTML = '<div class="nsr-status">搜索失败</div>';
    }
  };

  (window as any).navPlaySong = function(src: string, title: string, artist: string) {
    window.dispatchEvent(new CustomEvent('play-music', { detail: { src } }));
    searchPanel?.classList.add('hidden');
  };

  function escH(s: string) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
</script>