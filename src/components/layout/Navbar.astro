---
const navLinks = [
  { href: '/', label: 'Home', icon: '🏠' },
  { href: '/blog', label: 'Blog', icon: '📝' },
  { href: '/tags', label: 'Tags', icon: '🏷️' },
];
const currentPath = Astro.url.pathname;
---

<div
  id="navbar"
  class="lg-capsule fixed z-50 flex inset-x-0 top-3 mx-auto items-center justify-between px-3 sm:px-4"
  style="height: 44px; max-width: 520px;"
>
  <nav class="flex items-center gap-0.5 sm:gap-1">
    <a href="/" class="flex items-center gap-1.5 px-2 py-1.5 rounded-full hover:bg-white/5 transition-all group">
      <span class="w-6 h-6 rounded-lg bg-gradient-to-br from-[var(--accent-1)] to-[var(--accent-2)] flex items-center justify-center text-white font-bold text-[10px] shadow-sm group-hover:scale-110 transition-transform">L</span>
      <span class="font-semibold text-sm text-gradient hidden sm:block">Liquid Glass</span>
    </a>
    {navLinks.map((link) => (
      <a
        href={link.href}
        class={`lg-capsule ripple flex items-center gap-1 px-2.5 py-1.5 text-xs font-medium transition-all ${
          currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
            ? 'text-white'
            : 'text-[color:var(--text-secondary)] hover:text-[color:var(--text-primary)]'
        }`}
      >
        <span class="text-xs">{link.icon}</span>
        <span class="hidden sm:inline">{link.label}</span>
      </a>
    ))}
  </nav>

  <div class="flex items-center gap-1 relative" id="nav-right">
    {/* Single consolidated settings button */}
    <button
      id="nav-settings-btn" type="button"
      class="lg-capsule ripple flex items-center gap-1 px-2.5 py-1.5 text-xs font-medium text-[color:var(--text-secondary)] hover:text-[color:var(--text-primary)]"
      aria-label="设置"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path>
        <circle cx="12" cy="12" r="3"></circle>
      </svg>
      <svg id="nav-chevron" class="w-2.5 h-2.5 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
    </button>

    <div id="nav-dropdown" class="lg absolute top-full right-0 mt-2 w-48 rounded-2xl shadow-xl overflow-hidden hidden z-50 p-1.5">
      <a href="/admin" class="flex items-center gap-2 px-3 py-2 rounded-xl text-xs transition-all hover:bg-white/5" style="color: var(--text-secondary);">
        <span>⚙️</span><span>管理后台</span>
      </a>
      <button id="nav-settings-toggle" class="w-full flex items-center gap-2 px-3 py-2 rounded-xl text-xs transition-all hover:bg-white/5 text-left" style="color: var(--text-secondary);">
        <span>🎨</span><span>外观设置</span>
      </button>
      <button id="nav-style-toggle" class="w-full flex items-center gap-2 px-3 py-2 rounded-xl text-xs transition-all hover:bg-white/5 text-left" style="color: var(--text-secondary);">
        <span>🖌️</span><span>控件样式</span>
      </button>
      <button id="nav-theme-toggle" class="w-full flex items-center gap-2 px-3 py-2 rounded-xl text-xs transition-all hover:bg-white/5 text-left" style="color: var(--text-secondary);">
        <span id="theme-icon">🌙</span><span id="theme-label">暗色模式</span>
      </button>
    </div>
  </div>
</div>

<script>
  // Scroll shadow
  window.addEventListener('scroll', () => {
    const navbar = document.getElementById('navbar');
    if (!navbar) return;
    navbar.style.boxShadow = window.scrollY > 50 ? '0 8px 32px -8px rgba(0,0,0,0.4), 0 0 0 1px rgba(255,255,255,0.12) inset' : '';
  });

  const settingsBtn = document.getElementById('nav-settings-btn');
  const dropdown = document.getElementById('nav-dropdown');
  const chevron = document.getElementById('nav-chevron');

  settingsBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = !dropdown?.classList.contains('hidden');
    dropdown?.classList.toggle('hidden');
    chevron?.style.setProperty('transform', isOpen ? '' : 'rotate(180deg)');
  });

  document.addEventListener('click', (e) => {
    const navRight = document.getElementById('nav-right');
    if (navRight && !navRight.contains(e.target as Node)) {
      dropdown?.classList.add('hidden');
      chevron?.style.setProperty('transform', '');
    }
  });

  document.getElementById('nav-settings-toggle')?.addEventListener('click', () => {
    dropdown?.classList.add('hidden');
    window.dispatchEvent(new CustomEvent('toggle-settings'));
  });

  document.getElementById('nav-style-toggle')?.addEventListener('click', () => {
    dropdown?.classList.add('hidden');
    window.dispatchEvent(new CustomEvent('toggle-style-panel'));
  });

  // Theme toggle
  document.getElementById('nav-theme-toggle')?.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme') || 'dark';
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    document.getElementById('theme-icon').textContent = next === 'dark' ? '🌙' : '☀️';
    document.getElementById('theme-label').textContent = next === 'dark' ? '暗色模式' : '亮色模式';
    dropdown?.classList.add('hidden');
  });
</script>
