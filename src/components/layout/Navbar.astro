---
const navLinks = [
  { href: '/', label: 'Home', icon: '🏠' },
  { href: '/blog', label: 'Blog', icon: '📝' },
  { href: '/tags', label: 'Tags', icon: '🏷️' },
];
const currentPath = Astro.url.pathname;
---

<div
  id="navbar"
  class="lg-capsule fixed z-50 flex inset-x-0 top-3 mx-auto items-center justify-between px-3 sm:px-4"
  style="height: 44px; max-width: 520px;"
>
  <nav class="flex items-center gap-0.5 sm:gap-1">
    <a href="/" class="flex items-center gap-1.5 px-2 py-1.5 rounded-full hover:bg-white/5 transition-all group">
      <span class="w-6 h-6 rounded-lg bg-gradient-to-br from-[var(--accent-1)] to-[var(--accent-2)] flex items-center justify-center text-white font-bold text-[10px] shadow-sm group-hover:scale-110 transition-transform">L</span>
      <span class="font-semibold text-sm text-gradient hidden sm:block">Liquid Glass</span>
    </a>
    {navLinks.map((link) => (
      <a
        href={link.href}
        class:list={[
          'lg-capsule ripple flex items-center gap-1 px-2.5 py-1.5 text-xs font-medium transition-all',
          currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
            ? 'nav-active'
            : 'nav-inactive'
        ]}
      >
        <span class="text-xs">{link.icon}</span>
        <span class="hidden sm:inline">{link.label}</span>
      </a>
    ))}
  </nav>

  <div class="flex items-center gap-1 relative" id="nav-right">
    <button
      id="nav-settings-btn" type="button"
      class="lg-capsule ripple flex items-center gap-1 px-2.5 py-1.5 text-xs font-medium nav-inactive"
      aria-label="设置"
      onclick="window.dispatchEvent(new CustomEvent('toggle-settings'))"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path>
        <circle cx="12" cy="12" r="3"></circle>
      </svg>
    </button>
  </div>
</div>

<style>
  .nav-active {
    background: linear-gradient(135deg, var(--accent-1), var(--accent-2)) !important;
    color: white !important;
  }
  [data-theme="light"] .nav-active {
    color: white !important;
  }
  .nav-inactive {
    color: var(--text-secondary);
  }
  .nav-inactive:hover {
    color: var(--text-primary);
  }
</style>

<script>
  // Scroll shadow
  window.addEventListener('scroll', () => {
    const navbar = document.getElementById('navbar');
    if (!navbar) return;
    navbar.style.boxShadow = window.scrollY > 50 ? '0 8px 32px -8px rgba(0,0,0,0.4), 0 0 0 1px rgba(255,255,255,0.12) inset' : '';
  });
</script>
