---
const navLinks = [
  { href: '/', label: 'Home', icon: '🏠' },
  { href: '/blog', label: 'Blog', icon: '📝' },
  { href: '/tags', label: 'Tags', icon: '🏷️' },
];
const currentPath = Astro.url.pathname;
---

<div
  id="navbar"
  class="lg-capsule fixed z-50 flex inset-x-0 top-3 mx-auto items-center justify-between px-2 sm:px-3"
  style="height: 44px; max-width: 620px;"
>
  <nav class="flex items-center gap-0.5 sm:gap-1">
    <a href="/" class="flex items-center gap-1.5 px-2 py-1.5 rounded-full hover:bg-white/5 transition-all group">
      <span class="w-6 h-6 rounded-lg bg-gradient-to-br from-[var(--accent-1)] to-[var(--accent-2)] flex items-center justify-center text-white font-bold text-[10px] shadow-sm group-hover:scale-110 transition-transform">L</span>
      <span class="font-semibold text-sm text-gradient hidden sm:block">Liquid Glass</span>
    </a>
    {navLinks.map((link) => (
      <a
        href={link.href}
        class:list={[
          'lg-capsule ripple flex items-center gap-1 px-2.5 py-1.5 text-xs font-medium transition-all',
          currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
            ? 'nav-active'
            : 'nav-inactive'
        ]}
      >
        <span class="text-xs">{link.icon}</span>
        <span class="hidden sm:inline">{link.label}</span>
      </a>
    ))}
  </nav>

  <div class="flex items-center gap-1" id="nav-right">
    <div class="nav-search-box">
      <svg class="nav-search-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input id="nav-search-input" type="text" placeholder="搜索文章/歌曲..." class="nav-search-input" onkeydown="if(event.key==='Enter')navDoSearch()" />
      <div id="nav-search-panel" class="nav-search-panel hidden"></div>
    </div>

    <button
      id="nav-settings-btn" type="button"
      class="lg-capsule ripple flex items-center justify-center w-8 h-8 text-xs font-medium nav-inactive"
      aria-label="设置"
      onclick="window.dispatchEvent(new CustomEvent('toggle-settings'))"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path>
        <circle cx="12" cy="12" r="3"></circle>
      </svg>
    </button>
  </div>
</div>

<style>
  .nav-active {
    background: linear-gradient(135deg, var(--accent-1), var(--accent-2)) !important;
    color: white !important;
  }
  [data-theme="light"] .nav-active { color: white !important; }
  .nav-inactive { color: var(--text-secondary); }
  .nav-inactive:hover { color: var(--text-primary); }

  .nav-search-box {
    position: relative;
    display: flex;
    align-items: center;
    height: 30px;
    width: 140px;
    border-radius: 999px;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    padding: 0 0.5rem;
    gap: 0.3rem;
    transition: all 0.3s ease;
  }
  .nav-search-box:focus-within {
    width: 200px;
    border-color: var(--accent-1);
    box-shadow: 0 0 0 2px rgba(124, 58, 237, 0.12);
  }
  [data-theme="light"] .nav-search-box {
    background: rgba(0,0,0,0.04);
    border-color: rgba(0,0,0,0.1);
  }
  [data-theme="light"] .nav-search-box:focus-within {
    border-color: var(--accent-1);
    box-shadow: 0 0 0 2px rgba(124, 58, 237, 0.1);
  }
  .nav-search-icon {
    flex-shrink: 0;
    color: var(--text-muted);
  }
  .nav-search-input {
    flex: 1;
    min-width: 0;
    height: 100%;
    border: none;
    background: transparent;
    color: var(--text-primary);
    font-size: 0.7rem;
    outline: none;
  }
  .nav-search-input::placeholder { color: var(--text-muted); }

  .nav-search-panel {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    width: 300px;
    max-height: 320px;
    overflow-y: auto;
    border-radius: var(--card-radius);
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    backdrop-filter: blur(var(--card-blur)) saturate(150%);
    -webkit-backdrop-filter: blur(var(--card-blur)) saturate(150%);
    box-shadow: 0 12px 40px -8px rgba(0,0,0,0.3);
    padding: 0.4rem;
    z-index: 60;
    animation: slide-up 0.2s ease;
  }
  [data-theme="light"] .nav-search-panel {
    background: rgba(255,255,255,0.9);
    box-shadow: 0 12px 40px -8px rgba(0,0,0,0.1);
  }
  .nav-search-panel::-webkit-scrollbar { width: 3px; }
  .nav-search-panel::-webkit-scrollbar-thumb { background: var(--glass-border); border-radius: 100px; }
  .nsr-item {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.4rem 0.5rem; border-radius: 0.5rem;
    cursor: pointer; transition: background 0.15s;
  }
  .nsr-item:hover { background: rgba(255,255,255,0.08); }
  [data-theme="light"] .nsr-item:hover { background: rgba(0,0,0,0.04); }
  .nsr-art {
    width: 2rem; height: 2rem; border-radius: 0.375rem;
    background: linear-gradient(135deg, var(--accent-1), var(--accent-2));
    display: flex; align-items: center; justify-content: center;
    font-size: 0.65rem; flex-shrink: 0; overflow: hidden;
  }
  .nsr-art img { width: 100%; height: 100%; object-fit: cover; }
  .nsr-info { flex: 1; min-width: 0; }
  .nsr-title { font-size: 0.65rem; font-weight: 500; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .nsr-artist { font-size: 0.55rem; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .nsr-play {
    width: 1.4rem; height: 1.4rem; border-radius: 50%; border: none;
    background: linear-gradient(135deg, var(--accent-1), var(--accent-2));
    color: white; font-size: 0.45rem;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; flex-shrink: 0; opacity: 0; transition: opacity 0.15s;
  }
  .nsr-item:hover .nsr-play { opacity: 1; }
  .nsr-loading { text-align: center; padding: 0.6rem; font-size: 0.6rem; color: var(--text-muted); } .nsr-section { font-size: 0.55rem; font-weight: 600; color: var(--accent-1-light); padding: 0.3rem 0.5rem 0.15rem; text-transform: uppercase; letter-spacing: 0.05em; }
</style>

<script>
  window.addEventListener('scroll', () => {
    const navbar = document.getElementById('navbar');
    if (!navbar) return;
    navbar.style.boxShadow = window.scrollY > 50 ? '0 8px 32px -8px rgba(0,0,0,0.4), 0 0 0 1px rgba(255,255,255,0.12) inset' : '';
  });

  const searchInput = document.getElementById('nav-search-input') as HTMLInputElement;
  const searchPanel = document.getElementById('nav-search-panel');
  let debounce: any = null;

  searchInput?.addEventListener('input', () => {
    clearTimeout(debounce);
    const q = searchInput.value.trim();
    if (!q) { searchPanel?.classList.add('hidden'); return; }
    debounce = setTimeout(() => navDoSearch(), 400);
  });

  document.addEventListener('click', (e) => {
    const box = document.querySelector('.nav-search-box');
    if (box && !box.contains(e.target as Node)) {
      searchPanel?.classList.add('hidden');
    }
  });

  (window as any).navDoSearch = async function() {
    const q = searchInput?.value?.trim();
    if (!q || !searchPanel) return;
    searchPanel.classList.remove('hidden');
    searchPanel.innerHTML = '<div class="nsr-loading">搜索中...</div>';
    try {
      const resp = await fetch('/api/search?q=' + encodeURIComponent(q));
      const data = await resp.json();
      var songs = data.songs || [];
      var posts = data.posts || [];
      var html = '';
      if (posts.length > 0) {
        html += '<div class="nsr-section">📄 文章</div>';
        html += posts.slice(0, 4).map(function(p) {
          return '<a href="/blog/' + p.slug + '" class="nsr-item" style="text-decoration:none;"><div class="nsr-art">📝</div><div class="nsr-info"><div class="nsr-title">' + escH(p.title) + '</div><div class="nsr-artist">' + escH(p.description).substring(0, 30) + '...</div></div></a>';
        }).join('');
      }
      if (songs.length > 0) {
        html += '<div class="nsr-section">🎵 音乐</div>';
        html += songs.slice(0, 4).map(function(s) {
          var art = s.cover ? '<img src="' + s.cover + '" />' : '🎵';
          return '<div class="nsr-item" onclick="navPlaySong(\'' + (s.src||'').replace(/'/g, "\\'") + '\')"><div class="nsr-art">' + art + '</div><div class="nsr-info"><div class="nsr-title">' + escH(s.title) + '</div><div class="nsr-artist">' + escH(s.artist) + '</div></div><button class="nsr-play">▶</button></div>';
        }).join('');
      }
      if (!html) { searchPanel.innerHTML = '<div class="nsr-loading">未找到结果</div>'; return; }
      searchPanel.innerHTML = html;
    } catch {
      searchPanel.innerHTML = '<div class="nsr-loading">搜索失败</div>';
    }
  };

  (window as any).navPlaySong = function(src: string) {
    if (!src) return;
    window.dispatchEvent(new CustomEvent('play-music', { detail: { src } }));
    searchPanel?.classList.add('hidden');
  };

  function escH(s: string) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
</script>