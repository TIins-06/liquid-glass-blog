---
const year = new Date().getFullYear();
---

<footer class="glass-strong mt-20 py-8 px-6">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-2">
      <div class="w-6 h-6 rounded bg-gradient-to-br from-purple-500 to-cyan-400 flex items-center justify-center text-white font-bold text-xs">
        L
      </div>
      <span class="text-sm text-slate-400">© {year} Liquid Glass Blog</span>
    </div>
    <div class="flex items-center gap-4 text-sm text-slate-400">
      <a href="https://github.com" target="_blank" class="hover:text-white transition-colors">GitHub</a>
      <span class="text-slate-600">·</span>
      <span>Built with Astro</span>
      <span class="text-slate-600">·</span>
      <span>Deployed on Cloudflare</span>
    </div>
  </div>
</footer>
